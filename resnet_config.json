{
  "model": {
    "name": "resnet152",
    "layers": [3, 8, 36, 3],
    "bottleneck_expansion": 4,
    "num_classes": 1000
  },
  "input": {
    "batch": 1,
    "channels": 3,
    "height": 224,
    "width": 224
  },
  "abft": {
    "pad_each_side": 16,
    "rule": "single_dim_min(min(2*ceil16(M+1)*K*N, 2*M*ceil16(K+1)*N))"
  },
  "memory_model": {
    "bytes_per_param": 2,
    "note": "只统计权重访存，约 params * bytes_per_param"
  }
}
